# Copy to .env and fill in. EXPO_PUBLIC_ vars are readable in the app.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Backend base URL. For local dev use your machine's LAN IP (not localhost) so
# the phone can reach it, e.g. http://192.168.1.20:8000
EXPO_PUBLIC_API_URL=http://localhost:8000
