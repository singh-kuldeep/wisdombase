# Environment handling — Expo auto-selects by mode:
#   `expo start`   → loads .env.development   (dev backend / LAN)
#   `expo export`  → loads .env.production     (Railway backend)
# Both of those files are committed (EXPO_PUBLIC_* values ship in the client
# anyway, so there is no secret to hide). Put PERSONAL overrides — e.g. your
# own LAN IP — in .env.local, which is gitignored and wins over .env.development.
#
# This .env.example documents the variables; copy it to .env.local to override.
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Backend base URL. For a physical device use your machine's LAN IP (not
# localhost) so the phone can reach it, e.g. http://192.168.1.20:8000
EXPO_PUBLIC_API_URL=http://localhost:8000
