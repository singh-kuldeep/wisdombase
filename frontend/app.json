{
  "expo": {
    "name": "WisdomBase",
    "slug": "wisdombase",
    "owner": "singhkuldeep",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "wisdombase",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F9F5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wisdombase.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wisdombase.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "000c62e5-fc8b-49cf-803f-5ae0f8c2b335"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/000c62e5-fc8b-49cf-803f-5ae0f8c2b335"
    }
  }
}
