# Copy to .env and fill in.  ── LOCAL DEVELOPMENT template ──

# Environment this instance runs as: "development" or "production".
# Local + dev deploys use "development"; the Railway prod service sets
# "production" (see .env.production.example).
APP_ENV=development

# Supabase — from your project's API settings (Project Settings → API).
# For an isolated dev database, point these at a SEPARATE Supabase project than
# prod. Swapping these three values is the only change needed to switch DBs.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS allow-list (comma-separated) — only enforced when APP_ENV=production.
# In development all origins are allowed, so you can leave this blank locally.
# CORS_ORIGINS=https://wisdombase.expo.app

# Shared Anthropic key used to answer each user's free questions (common to all
# users). After a user exhausts their free allowance they must add their own key.
ANTHROPIC_API_KEY=

# Optional: how many free questions each user gets on the shared key. Defaults to
# 20 (see backend/config.py). Set here only to override per-deployment.
# FREE_QUESTION_LIMIT=20
