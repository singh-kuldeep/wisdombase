# Supabase — from your project's API settings
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared Anthropic key used to answer each user's free questions (common to all
# users). After a user exhausts their free allowance they must add their own key.
ANTHROPIC_API_KEY=

# Optional: how many free questions each user gets on the shared key. Defaults to
# 10 (see backend/config.py). Set here only to override per-deployment.
# FREE_QUESTION_LIMIT=10
