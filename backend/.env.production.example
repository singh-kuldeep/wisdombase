# Reference for the PRODUCTION backend environment variables.
# These are NOT loaded from a file in prod — set them in the Railway dashboard
# (or `railway variables set KEY=value`). This file exists only to document the
# expected prod configuration. Do NOT put real secret values here.

# Marks this instance as production: enables the CORS allow-list below.
APP_ENV=production

# Production Supabase project.
SUPABASE_URL=https://YOUR-PROD-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-prod-service-role-key

# Restrict browser origins in prod (comma-separated). Native mobile apps are
# unaffected (no Origin header). Include every web origin that calls the API.
CORS_ORIGINS=https://wisdombase.expo.app

# Shared Anthropic key for the free-question allowance.
ANTHROPIC_API_KEY=sk-ant-...
FREE_QUESTION_LIMIT=20

# Optional transactional email (account-deletion confirmations).
# SENDGRID_API_KEY=
# FROM_EMAIL=noreply@wisdombase.com
